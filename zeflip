-- ══════════════════════════════════════
-- DEVICE DETECTION — CLOUDPHONE SAFE
-- ══════════════════════════════════════
-- CloudPhone: TouchEnabled=false, KeyboardEnabled=false, tapi bukan PC asli.
-- Deteksi lebih robust: cek platform + layar + input devices.
local function DetectMobile()
    -- Method 1: Touch ada (standar mobile)
    if UIS.TouchEnabled then return true end

    -- Method 2: Tidak ada keyboard DAN tidak ada mouse = kemungkinan emulator/cloudphone
    if not UIS.KeyboardEnabled and not UIS.MouseEnabled then return true end

    -- Method 3: Platform check via UserAgent-like (Roblox internal)
    local plat = pcall(function()
        -- GuiService platform hint
        local gs = game:GetService("GuiService")
        if gs then
            local ok, result = pcall(function() return gs:IsTenFootInterface() end)
            -- Console/TV bukan mobile tapi bukan desktop biasa juga
        end
    end)

    -- Method 4: Screen ratio + kecilnya layar = indikasi mobile
    local cam = workspace.CurrentCamera
    if cam then
        local vp = cam.ViewportSize
        -- Layar < 800px lebar kemungkinan besar mobile/tablet
        if vp.X < 800 then return true end
        -- Aspect ratio portrait = mobile
        if vp.Y > vp.X then return true end
    end

    -- Method 5: Tidak ada mouse sama sekali
    if not UIS.MouseEnabled then return true end

    return false
end

local mob = DetectMobile()

-- ══════════════════════════════════════
-- ANTI-AFK PROTOCOL [TANPA W KEY]
-- Metode: VirtualUser Button2 + Jump
-- Tidak mengganggu movement player
-- ══════════════════════════════════════
local _afk = true

-- Metode 1: VirtualUser Button2 (klik kanan virtual, tidak memindahkan karakter)
pcall(function()
    local VU = game:GetService("VirtualUser")
    Plr.Idled:Connect(function()
        if _afk then
            -- Button2 = klik kanan, tidak ganggu WASD/movement
            VU:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.1)
            VU:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end
    end)
end)

-- Metode 2: Jump periodik (tidak memindahkan karakter secara horizontal)
-- Interval 4 menit — jarang, tidak mengganggu gameplay
pcall(function()
    task.spawn(function()
        while task.wait(240) do
            if _afk and Plr.Character then
                pcall(function()
                    local hum = Plr.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        hum.Jump = true
                    end
                end)
            end
        end
    end)
end)

-- Metode 3: Mouse move virtual (sangat kecil, tidak terlihat, reset posisi)
-- Interval 90 detik sebagai backup
pcall(function()
    local VIM = game:GetService("VirtualInputManager")
    task.spawn(function()
        while task.wait(90) do
            if _afk then
                pcall(function()
                    -- Gerak mouse 1px lalu balik — tidak mengganggu gameplay
                    VIM:SendMouseMoveEvent(1, 0, game)
                    task.wait(0.05)
                    VIM:SendMouseMoveEvent(-1, 0, game)
                end)
            end
        end
    end)
end)

-- ══════════════════════════════════════
-- PERFORMANCE DETECTION
-- ══════════════════════════════════════
local perfMode = mob  -- Mobile selalu lite mode
pcall(function()
    if not mob then
        local t0 = tick()
        local frames = 0
        local hb = RS.Heartbeat:Connect(function() frames = frames + 1 end)
        task.delay(1, function()
            hb:Disconnect()
            local fps = frames / math.max(tick() - t0, 0.01)
            if fps < 35 then perfMode = true end
        end)
    end
end)

-- ══════════════════════════════════════
-- LIGHTWEIGHT UTILS
-- ══════════════════════════════════════
local function tw(o, p, d, s2, dr)
    if perfMode then d = (d or 0.25) * 0.4 end
    local t = TS:Create(o, TweenInfo.new(d or 0.25, s2 or Enum.EasingStyle.Quad, dr or Enum.EasingDirection.Out), p)
    t:Play()
    return t
end

local function rc(p, r)
    local u = Instance.new("UICorner")
    u.CornerRadius = UDim.new(0, r or 3)
    u.Parent = p
    return u
end

local function st(p, col, th, tr)
    local u = Instance.new("UIStroke")
    u.Color = col or Color3.new(1, 1, 1)
    u.Thickness = th or 1
    u.Transparency = tr or 0.6
    u.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    u.Parent = p
    return u
end

local function pd(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft = UDim.new(0, l or 0)
    u.PaddingRight = UDim.new(0, r or 0)
    u.Parent = p
    return u
end

local function ll(p, dir, padding, al)
    local u = Instance.new("UIListLayout")
    u.FillDirection = dir or Enum.FillDirection.Vertical
    u.Padding = UDim.new(0, padding or 5)
    u.HorizontalAlignment = al or Enum.HorizontalAlignment.Center
    u.SortOrder = Enum.SortOrder.LayoutOrder
    u.Parent = p
    return u
end

local function glow(lbl, col, intensity)
    if not perfMode then
        lbl.TextStrokeColor3 = col
        lbl.TextStrokeTransparency = intensity or 0.72
    end
end

