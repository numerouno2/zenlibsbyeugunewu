                if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
                    if hd then h2 = math.clamp((i.Position.X - hB.AbsolutePosition.X) / hB.AbsoluteSize.X, 0, 1); UC() end
                    if sd then s2 = math.clamp((i.Position.X - sB.AbsolutePosition.X) / sB.AbsoluteSize.X, 0, 1); UC() end
                    if vd then v2 = math.clamp((i.Position.X - vB.AbsolutePosition.X) / vB.AbsoluteSize.X, 0, 1); UC() end
                end
            end)
            local cpb = Instance.new("TextButton")
            cpb.BackgroundTransparency = 1
            cpb.Size = UDim2.new(1, 0, 0, 34)
            cpb.Text = ""
            cpb.ZIndex = 16
            cpb.Parent = f
            cpb.MouseButton1Click:Connect(function()
                op = not op
                if op then
                    tw(f, { Size = UDim2.new(1, 0, 0, 85) }, 0.18, Enum.EasingStyle.Quint)
                    tw(pa, { Size = UDim2.new(1, -16, 0, 42) }, 0.18, Enum.EasingStyle.Quint)
                else
                    tw(f, { Size = UDim2.new(1, 0, 0, 34) }, 0.18, Enum.EasingStyle.Quint)
                    tw(pa, { Size = UDim2.new(1, -16, 0, 0) }, 0.18, Enum.EasingStyle.Quint)
                end
            end)
        end

        return tab
    end

