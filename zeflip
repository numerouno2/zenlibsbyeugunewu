-- ANTI-AFK PROTOCOL [FIXED - NO W KEY]
-- Method: VirtualUser + Camera CFrame rotate + Jump
-- Tidak pakai W/KeyEvent agar tidak ganggu gameplay
-- ══════════════════════════════════════
local _afk = true

-- Method 1: VirtualUser Button2 (paling aman, tidak ada gerakan)
pcall(function()
    local VU = game:GetService("VirtualUser")
    Plr.Idled:Connect(function()
        if _afk then
            VU:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.1)
            VU:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end
    end)
end)

-- Method 2: Rotate camera sedikit (tidak gerakkan karakter sama sekali)
pcall(function()
    task.spawn(function()
        while task.wait(50) do
            if _afk then
                pcall(function()
                    local cam = workspace.CurrentCamera
                    if cam then
                        local cf = cam.CFrame
                        cam.CFrame = cf * CFrame.Angles(0, math.rad(0.01), 0)
                        task.wait(0.2)
                        cam.CFrame = cf
                    end
                end)
            end
        end
    end)
end)

-- Method 3: Jump periodik (backup, tiap 4 menit)
pcall(function()
    task.spawn(function()
        while task.wait(240) do
            if _afk and Plr.Character then
                pcall(function()
                    local hum = Plr.Character:FindFirstChildOfClass("Humanoid")
                    if hum then hum.Jump = true end
                end)
            end
        end
    end)
end)

-- ══════════════════════════════════════
-- DEVICE DETECTION — FIXED FOR CLOUDPHONE/EMULATOR
-- CloudPhone: TouchEnabled=true TAPI juga KeyboardEnabled=true
-- Real mobile: TouchEnabled=true, KeyboardEnabled=false
-- Tambah cek screen ratio dan gyro sebagai konfirmasi
-- ══════════════════════════════════════
local function detectMobile()
    -- Cek dasar
    local touch = UIS.TouchEnabled
    local keyboard = UIS.KeyboardEnabled
    local gamepad = UIS.GamepadEnabled

    -- Real mobile: punya touch, TIDAK punya keyboard fisik
    -- CloudPhone/emulator: biasanya punya keduanya
    if touch and not keyboard then
        return true  -- real mobile pasti
    end

    if not touch then
        return false  -- desktop pasti
    end

    -- Zona abu-abu: touch=true, keyboard=true (bisa CloudPhone atau tablet+keyboard)
    -- Cek screen size: mobile biasanya < 768px lebar di portrait
    local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local minSide = math.min(vp.X, vp.Y)
    local maxSide = math.max(vp.X, vp.Y)
    local ratio = maxSide / minSide

    -- Mobile: layar kecil (minSide < 600) ATAU rasio portrait tinggi
    if minSide < 600 then
        return true
    end

    -- Kalau besar (tablet/desktop emulator), treat as desktop
    return false
end

local mob = detectMobile()

-- Performance mode
local perfMode = mob
pcall(function()
    if not mob then
        local t0 = tick()
        local frames = 0
        local hb = RS.Heartbeat:Connect(function() frames = frames + 1 end)
        task.delay(1, function()
            hb:Disconnect()
            local fps = frames / math.max(tick() - t0, 0.01)
            if fps < 35 then perfMode = true end
        end)
    end
end)

-- ══════════════════════════════════════
-- LIGHTWEIGHT UTILS
-- ══════════════════════════════════════
local function tw(o, p, d, s2, dr)
    if perfMode then d = (d or 0.25) * 0.4 end
    local t = TS:Create(o, TweenInfo.new(d or 0.25, s2 or Enum.EasingStyle.Quad, dr or Enum.EasingDirection.Out), p)
    t:Play()
    return t
end

local function rc(p, r)
    local u = Instance.new("UICorner")
    u.CornerRadius = UDim.new(0, r or 3)
    u.Parent = p
    return u
end

local function st(p, col, th, tr)
    local u = Instance.new("UIStroke")
    u.Color = col or Color3.new(1, 1, 1)
    u.Thickness = th or 1
    u.Transparency = tr or 0.6
    u.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    u.Parent = p
    return u
end

local function pd(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft = UDim.new(0, l or 0)
    u.PaddingRight = UDim.new(0, r or 0)
    u.Parent = p
    return u
end

local function ll(p, dir, padding, al)
    local u = Instance.new("UIListLayout")
    u.FillDirection = dir or Enum.FillDirection.Vertical
    u.Padding = UDim.new(0, padding or 5)
    u.HorizontalAlignment = al or Enum.HorizontalAlignment.Center
    u.SortOrder = Enum.SortOrder.LayoutOrder
    u.Parent = p
    return u
end

-- GLOW DIHILANGKAN — fungsi ini sekarang no-op
-- Semua teks tanpa TextStroke agar lebih jelas dan tajam
local function glow(lbl, col, intensity)
    -- Sengaja dikosongkan: glow dihapus per permintaan
    -- Agar font lebih jelas dan terbaca
    if lbl then
        lbl.TextStrokeTransparency = 1
    end
end

