            cur.AnchorPoint = Vector2.new(0.5, 0.5)
            cur.Position = UDim2.new(pct, 0, 0.5, 0)
            cur.ZIndex = 14
            cur.Parent = bg
            local sliding = false
            local function US(input)
                local rel = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
                val = math.clamp(math.floor((min + (max - min) * rel) / inc + 0.5) * inc, min, max)
                local p = (val - min) / (max - min)
                fill.Size = UDim2.new(p, 0, 1, 0)
                cur.Position = UDim2.new(p, 0, 0.5, 0)
