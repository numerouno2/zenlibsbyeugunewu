-- ══════════════════════════════════════
-- TWEEN CACHE
-- ══════════════════════════════════════
local _tweenCache = {}
local function tw(obj, props, dur, style, dir)
    if perfMode then dur = (dur or 0.25) * 0.5 end
    dur   = dur   or 0.25
    style = style or Enum.EasingStyle.Quad
    dir   = dir   or Enum.EasingDirection.Out
    local key = dur.."_"..tostring(style).."_"..tostring(dir)
    if not _tweenCache[key] then
        _tweenCache[key] = TweenInfo.new(dur, style, dir)
    end
    local t = TS:Create(obj, _tweenCache[key], props)
    t:Play()
    return t
end

-- ══════════════════════════════════════
-- UTILS
-- ══════════════════════════════════════
local function rc(p, r)
    local u = Instance.new("UICorner")
    u.CornerRadius = UDim.new(0, r or 3)
    u.Parent = p
    return u
end

local function st(p, col, th, tr)
    local u = Instance.new("UIStroke")
    u.Color            = col or Color3.new(1,1,1)
    u.Thickness        = th  or 1
    u.Transparency     = tr  or 0.6
    u.ApplyStrokeMode  = Enum.ApplyStrokeMode.Border
    u.Parent = p
    return u
end

local function pd(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.Parent = p
    return u
end

local function ll(p, dir, padding, al)
    local u = Instance.new("UIListLayout")
    u.FillDirection       = dir or Enum.FillDirection.Vertical
    u.Padding             = UDim.new(0, padding or 5)
    u.HorizontalAlignment = al  or Enum.HorizontalAlignment.Center
    u.SortOrder           = Enum.SortOrder.LayoutOrder
    u.Parent = p
    return u
end

local function glow(lbl, col, intensity)
    if not perfMode then
        lbl.TextStrokeColor3       = col
        lbl.TextStrokeTransparency = intensity or 0.72
    end
end

