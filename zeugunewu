        -- ── SLIDER ──
        function tab:AddSlider(cfg4)
            cfg4 = cfg4 or {}
            local name = cfg4.Name or "slider"
            local flag = cfg4.Flag or name
            local min,max = cfg4.Min or 0, cfg4.Max or 100
            local val = math.clamp(cfg4.Default or min, min, max)
            local inc = cfg4.Increment or 1
            local suf = cfg4.Suffix or ""
            local cb = cfg4.Callback or function() end
            lib.Flags[flag] = val

            local f = Card(50)

            -- Name + value on top
            local nl2 = Instance.new("TextLabel")
            nl2.BackgroundTransparency = 1
            nl2.Size = UDim2.new(0.6,0,0,18)
