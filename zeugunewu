                        count = count + 1
                    end
                end
                totalW = totalW + count * (TAB_BTN_W + 3)
                TabBar.CanvasSize = UDim2.new(0, totalW, 0, 0)
                -- Pastikan canvas dimulai dari posisi 0 (tab pertama selalu kelihatan)
