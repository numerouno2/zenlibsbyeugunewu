        local function SelectTab()
            for _, t2 in ipairs(lib.Tabs) do
                t2.Page.Visible = false
                if mob then
                    t2.Button.BackgroundColor3       = T.Card
                    t2.Button.BackgroundTransparency = 0.35
                    t2.Button.TextColor3             = T.TextDim
                else
                    t2.Button.Text                   = "   "..t2.Name:lower().."_"
                    t2.Button.TextColor3             = T.TextDark
                    t2.Button.BackgroundTransparency = 1
                end
            end
            Page.Visible = true
            if mob then
                TabBtn.BackgroundColor3       = T.Accent
                TabBtn.BackgroundTransparency = 0.1
                TabBtn.TextColor3             = T.Bg

                -- Scroll ke tab yang diklik agar selalu kelihatan
                task.defer(function()
                    local tabIndex = 0
                    for i, t2 in ipairs(lib.Tabs) do
                        if t2 == tab then tabIndex = i; break end
                    end
                    if tabIndex > 0 then
                        local scrollX = math.max(0, (tabIndex-1) * (TAB_BTN_W + 3) - 10)
                        TabBar.CanvasPosition = Vector2.new(scrollX, 0)
                    end
                end)
            else
                TabBtn.Text                   = " ► "..tabName:lower().."_▌"
                TabBtn.TextColor3             = T.Accent
                TabBtn.BackgroundTransparency = 0.7
                TabBtn.BackgroundColor3       = T.Card
            end
            lib.CurrentTab = tab
        end

        TabBtn.MouseButton1Click:Connect(SelectTab)
        if not mob then
            TabBtn.MouseEnter:Connect(function()
                if lib.CurrentTab ~= tab then TabBtn.TextColor3 = T.TextDim end
            end)
            TabBtn.MouseLeave:Connect(function()
                if lib.CurrentTab ~= tab then TabBtn.TextColor3 = T.TextDark end
            end)
        end

        table.insert(lib.Tabs, tab)
        if #lib.Tabs == 1 then SelectTab() end

