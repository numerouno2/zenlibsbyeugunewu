            vl.Text = "["..tostring(val)..suf.."]"
            vl.TextColor3 = T.Accent
            vl.TextSize = 10
            vl.ZIndex = 12
            vl.Parent = f
            c(vl, 2)
            s(vl, T.Accent, 1, 0.6)
            glow(vl, T.AccentGlow, 0.65)

            -- Track (retro style - thin line)
            local bg = Instance.new("Frame")
            bg.BackgroundColor3 = T.Border
            bg.BorderSizePixel = 0
            bg.Size = UDim2.new(1,-20,0,4)
            bg.Position = UDim2.new(0,10,0,34)
            bg.ZIndex = 11
            bg.Parent = f
            c(bg, 1)

            local pct = (val-min)/(max-min)
            local fill = Instance.new("Frame")
            fill.BackgroundColor3 = T.Accent
            fill.BorderSizePixel = 0
            fill.Size = UDim2.new(pct,0,1,0)
            fill.ZIndex = 12
            fill.Parent = bg
            c(fill, 1)

            -- Cursor (thin vertical bar instead of circle knob)
            local cursor = Instance.new("Frame")
            cursor.BackgroundColor3 = T.TextBright
            cursor.BorderSizePixel = 0
            cursor.Size = UDim2.new(0,2,0,14)
            cursor.AnchorPoint = Vector2.new(0.5,0.5)
            cursor.Position = UDim2.new(pct,0,0.5,0)
            cursor.ZIndex = 14
            cursor.Parent = bg

            -- Glow on cursor
            local cGlow = Instance.new("Frame")
            cGlow.BackgroundColor3 = T.Accent
            cGlow.BackgroundTransparency = 0.6
            cGlow.BorderSizePixel = 0
            cGlow.Size = UDim2.new(0,6,0,14)
            cGlow.AnchorPoint = Vector2.new(0.5,0.5)
            cGlow.Position = UDim2.new(pct,0,0.5,0)
            cGlow.ZIndex = 13
            cGlow.Parent = bg

            local sliding = false
            local function UpdSlider(input)
                local rel = math.clamp((input.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
                val = math.clamp(math.floor((min+(max-min)*rel)/inc+0.5)*inc, min, max)
                local p = (val-min)/(max-min)
                tw(fill,{Size=UDim2.new(p,0,1,0)},0.04)
                tw(cursor,{Position=UDim2.new(p,0,0.5,0)},0.04)
                tw(cGlow,{Position=UDim2.new(p,0,0.5,0)},0.04)
                vl.Text = "["..tostring(val)..suf.."]"
                lib.Flags[flag]=val; pcall(cb,val)
            end

            local ib = Instance.new("TextButton")
            ib.BackgroundTransparency=1; ib.Size=UDim2.new(1,0,0,22); ib.Position=UDim2.new(0,0,0,24)
            ib.Text=""; ib.ZIndex=16; ib.Parent=f

            ib.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=true; UpdSlider(i); tw(cursor,{Size=UDim2.new(0,3,0,18)},0.1) end end)
            ib.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=false; tw(cursor,{Size=UDim2.new(0,2,0,14)},0.1) end end)
            UIS.InputChanged:Connect(function(i) if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then UpdSlider(i) end end)

            return {
                Set=function(_,v2) val=math.clamp(v2,min,max); local p=(val-min)/(max-min); tw(fill,{Size=UDim2.new(p,0,1,0)},0.2); tw(cursor,{Position=UDim2.new(p,0,0.5,0)},0.2); tw(cGlow,{Position=UDim2.new(p,0,0.5,0)},0.2); vl.Text="["..tostring(val)..suf.."]"; lib.Flags[flag]=val; pcall(cb,val) end,
                Get=function() return val end
            }
        end

