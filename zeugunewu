            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 4
            label.Parent = frame

            local selectedLabel = Instance.new("TextLabel")
            selectedLabel.BackgroundTransparency = 1
            selectedLabel.Size = UDim2.new(0.45, -10, 0, 38)
            selectedLabel.Position = UDim2.new(0.5, 0, 0, 0)
            selectedLabel.Font = Enum.Font.Gotham
            selectedLabel.TextColor3 = self.Theme.Accent
            selectedLabel.TextSize = 11
            selectedLabel.TextXAlignment = Enum.TextXAlignment.Right
            selectedLabel.TextTruncate = Enum.TextTruncate.AtEnd
            selectedLabel.ZIndex = 4
            selectedLabel.Parent = frame

            local arrow2 = Instance.new("TextLabel")
            arrow2.BackgroundTransparency = 1
            arrow2.Size = UDim2.new(0, 20, 0, 38)
            arrow2.Position = UDim2.new(1, -25, 0, 0)
            arrow2.Font = Enum.Font.GothamBold
            arrow2.Text = "▾"
            arrow2.TextColor3 = self.Theme.TextDim
            arrow2.TextSize = 14
            arrow2.ZIndex = 4
            arrow2.Parent = frame

            -- Option container
            local optionContainer = Instance.new("Frame")
            optionContainer.BackgroundTransparency = 1
            optionContainer.Size = UDim2.new(1, -16, 0, 0)
            optionContainer.Position = UDim2.new(0, 8, 0, 40)
            optionContainer.ClipsDescendants = true
            optionContainer.ZIndex = 4
            optionContainer.Parent = frame

            local optLayout = Instance.new("UIListLayout")
            optLayout.Padding = UDim.new(0, 2)
            optLayout.SortOrder = Enum.SortOrder.LayoutOrder
            optLayout.Parent = optionContainer

            local function GetDisplayText()
                if multi then
                    local items = {}
                    for k, v in pairs(selected) do
                        if v then table.insert(items, k) end
                    end
                    return #items > 0 and table.concat(items, ", ") or "None"
                else
                    return tostring(selected)
                end
            end

            selectedLabel.Text = GetDisplayText()

            local optionButtons = {}

            local function BuildOptions()
                for _, btn in pairs(optionButtons) do
                    btn:Destroy()
                end
                optionButtons = {}

                for i, opt in ipairs(options) do
                    local optBtn = Instance.new("TextButton")
                    optBtn.BackgroundColor3 = self.Theme.Input
                    optBtn.BackgroundTransparency = 0.3
                    optBtn.Size = UDim2.new(1, 0, 0, 28)
                    optBtn.Font = Enum.Font.Gotham
                    optBtn.Text = "  " .. opt
                    optBtn.TextColor3 = self.Theme.TextDim
                    optBtn.TextSize = 12
                    optBtn.TextXAlignment = Enum.TextXAlignment.Left
                    optBtn.BorderSizePixel = 0
                    optBtn.AutoButtonColor = false
                    optBtn.ZIndex = 5
                    optBtn.Parent = optionContainer

                    local optCorner = Instance.new("UICorner")
                    optCorner.CornerRadius = UDim.new(0, 6)
                    optCorner.Parent = optBtn

                    -- Highlight selected
                    if multi then
                        if selected[opt] then
                            optBtn.TextColor3 = self.Theme.Accent
                            optBtn.BackgroundTransparency = 0.1
                        end
                    else
                        if selected == opt then
                            optBtn.TextColor3 = self.Theme.Accent
                            optBtn.BackgroundTransparency = 0.1
                        end
                    end

                    optBtn.MouseButton1Click:Connect(function()
                        if multi then
                            selected[opt] = not selected[opt]
                            if selected[opt] then
                                CreateTween(optBtn, {TextColor3 = self.Theme.Accent, BackgroundTransparency = 0.1}, 0.15):Play()
                            else
                                CreateTween(optBtn, {TextColor3 = self.Theme.TextDim, BackgroundTransparency = 0.3}, 0.15):Play()
                            end
                        else
                            selected = opt
                            for _, b in pairs(optionButtons) do
                                CreateTween(b, {TextColor3 = self.Theme.TextDim, BackgroundTransparency = 0.3}, 0.15):Play()
                            end
                            CreateTween(optBtn, {TextColor3 = self.Theme.Accent, BackgroundTransparency = 0.1}, 0.15):Play()
                        end
                        selectedLabel.Text = GetDisplayText()
                        self.Flags[flag] = selected
                        pcall(callback, selected)
                    end)

                    optBtn.MouseEnter:Connect(function()
                        CreateTween(optBtn, {BackgroundTransparency = 0.1}, 0.1):Play()
                    end)
                    optBtn.MouseLeave:Connect(function()
                        local isSelected = multi and selected[opt] or (selected == opt)
                        if not isSelected then
                            CreateTween(optBtn, {BackgroundTransparency = 0.3}, 0.1):Play()
                        end
                    end)

                    table.insert(optionButtons, optBtn)
                end
            end

            BuildOptions()

            -- Toggle dropdown
            local headerBtn = Instance.new("TextButton")
            headerBtn.BackgroundTransparency = 1
            headerBtn.Size = UDim2.new(1, 0, 0, 38)
            headerBtn.Text = ""
            headerBtn.ZIndex = 6
            headerBtn.Parent = frame

            headerBtn.MouseButton1Click:Connect(function()
                opened = not opened
                if opened then
                    local totalHeight = #options * 30 + 6
                    CreateTween(frame, {Size = UDim2.new(1, 0, 0, 38 + totalHeight + 8)}, 0.25, Enum.EasingStyle.Quart):Play()
                    CreateTween(optionContainer, {Size = UDim2.new(1, -16, 0, totalHeight)}, 0.25, Enum.EasingStyle.Quart):Play()
                    arrow2.Text = "▴"
                else
                    CreateTween(frame, {Size = UDim2.new(1, 0, 0, 38)}, 0.25, Enum.EasingStyle.Quart):Play()
                    CreateTween(optionContainer, {Size = UDim2.new(1, -16, 0, 0)}, 0.25, Enum.EasingStyle.Quart):Play()
                    arrow2.Text = "▾"
                end
            end)

            local dropObj = {}
            function dropObj:Set(val)
                selected = val
                selectedLabel.Text = GetDisplayText()
                self.Flags[flag] = selected
                pcall(callback, selected)
            end
            function dropObj:Refresh(newOptions)
                options = newOptions
                BuildOptions()
            end
            function dropObj:Get()
                return selected
            end
            return dropObj
        end

