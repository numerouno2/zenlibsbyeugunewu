            trackCorner.Parent = track

            -- Toggle knob
            local knob = Instance.new("Frame")
            knob.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
            knob.BorderSizePixel = 0
            knob.Size = UDim2.new(0, 18, 0, 18)
            knob.Position = UDim2.new(0, 2, 0.5, -9)
            knob.ZIndex = 5
            knob.Parent = track

            local knobCorner = Instance.new("UICorner")
            knobCorner.CornerRadius = UDim.new(1, 0)
            knobCorner.Parent = knob

            local function UpdateToggle()
                if toggled then
                    CreateTween(track, {BackgroundColor3 = self.Theme.Accent}, 0.2):Play()
                    CreateTween(knob, {
                        Position = UDim2.new(1, -20, 0.5, -9),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    }, 0.2, Enum.EasingStyle.Back):Play()
                else
                    CreateTween(track, {BackgroundColor3 = self.Theme.Toggle}, 0.2):Play()
                    CreateTween(knob, {
                        Position = UDim2.new(0, 2, 0.5, -9),
                        BackgroundColor3 = Color3.fromRGB(200, 200, 200)
                    }, 0.2, Enum.EasingStyle.Back):Play()
                end
            end

            local btn = Instance.new("TextButton")
            btn.BackgroundTransparency = 1
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.Text = ""
            btn.ZIndex = 6
            btn.Parent = frame

            btn.MouseButton1Click:Connect(function()
                toggled = not toggled
                self.Flags[flag] = toggled
                UpdateToggle()
                pcall(callback, toggled)
            end)

            -- Hover
            btn.MouseEnter:Connect(function()
                CreateTween(frame, {BackgroundTransparency = 0.15}, 0.15):Play()
            end)
            btn.MouseLeave:Connect(function()
                CreateTween(frame, {BackgroundTransparency = 0.3}, 0.15):Play()
            end)

            if default then UpdateToggle() end

            local toggleObj = {}
            function toggleObj:Set(val)
                toggled = val
                self.Flags[flag] = val
                UpdateToggle()
                pcall(callback, val)
            end
            function toggleObj:Get()
                return toggled
            end
            return toggleObj
        end

        -- ═══════════════════════════════════
        -- SLIDER
        -- ═══════════════════════════════════
        function tab:AddSlider(config)
            config = config or {}
            local name = config.Name or "Slider"
            local flag = config.Flag or name
            local min = config.Min or 0
            local max = config.Max or 100
            local default = config.Default or min
            local increment = config.Increment or 1
            local suffix = config.Suffix or ""
            local callback = config.Callback or function() end

            local value = default
            self.Flags[flag] = value

            local frame = CreateElementFrame(52)

            -- Label
            local label = Instance.new("TextLabel")
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(0.6, -10, 0, 22)
            label.Position = UDim2.new(0, 12, 0, 4)
            label.Font = Enum.Font.GothamSemibold
            label.Text = name
            label.TextColor3 = self.Theme.Text
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 4
            label.Parent = frame

            -- Value display
            local valueLabel = Instance.new("TextLabel")
            valueLabel.BackgroundTransparency = 1
            valueLabel.Size = UDim2.new(0.4, -10, 0, 22)
            valueLabel.Position = UDim2.new(0.6, 0, 0, 4)
            valueLabel.Font = Enum.Font.GothamBold
            valueLabel.Text = tostring(value) .. suffix
            valueLabel.TextColor3 = self.Theme.Accent
            valueLabel.TextSize = 13
            valueLabel.TextXAlignment = Enum.TextXAlignment.Right
            valueLabel.ZIndex = 4
            valueLabel.Parent = frame

            -- Slider track
            local sliderBg = Instance.new("Frame")
            sliderBg.BackgroundColor3 = self.Theme.Slider
            sliderBg.BorderSizePixel = 0
            sliderBg.Size = UDim2.new(1, -24, 0, 6)
            sliderBg.Position = UDim2.new(0, 12, 0, 36)
            sliderBg.ZIndex = 4
            sliderBg.Parent = frame

            local sliderBgCorner = Instance.new("UICorner")
            sliderBgCorner.CornerRadius = UDim.new(1, 0)
            sliderBgCorner.Parent = sliderBg

            -- Fill
            local fillPercent = (value - min) / (max - min)
            local sliderFill = Instance.new("Frame")
            sliderFill.BackgroundColor3 = self.Theme.Accent
            sliderFill.BorderSizePixel = 0
            sliderFill.Size = UDim2.new(fillPercent, 0, 1, 0)
            sliderFill.ZIndex = 5
            sliderFill.Parent = sliderBg

            local fillCorner = Instance.new("UICorner")
            fillCorner.CornerRadius = UDim.new(1, 0)
            fillCorner.Parent = sliderFill

            -- Gradient on fill
            local fillGrad = Instance.new("UIGradient")
            fillGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, self.Theme.AccentDark),
                ColorSequenceKeypoint.new(1, self.Theme.Accent),
            })
            fillGrad.Parent = sliderFill

            -- Knob
            local sliderKnob = Instance.new("Frame")
            sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            sliderKnob.BorderSizePixel = 0
            sliderKnob.Size = UDim2.new(0, 14, 0, 14)
            sliderKnob.AnchorPoint = Vector2.new(0.5, 0.5)
            sliderKnob.Position = UDim2.new(fillPercent, 0, 0.5, 0)
            sliderKnob.ZIndex = 6
            sliderKnob.Parent = sliderBg

            local knobCorner = Instance.new("UICorner")
            knobCorner.CornerRadius = UDim.new(1, 0)
            knobCorner.Parent = sliderKnob

            -- Interaction
            local sliding = false

            local function UpdateSlider(input)
                local absPos = sliderBg.AbsolutePosition.X
                local absSize = sliderBg.AbsoluteSize.X
                local relativeX = math.clamp((input.Position.X - absPos) / absSize, 0, 1)

                local rawValue = min + (max - min) * relativeX
                value = math.floor(rawValue / increment + 0.5) * increment
                value = math.clamp(value, min, max)

                local percent = (value - min) / (max - min)
                CreateTween(sliderFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.08):Play()
                CreateTween(sliderKnob, {Position = UDim2.new(percent, 0, 0.5, 0)}, 0.08):Play()
                valueLabel.Text = tostring(value) .. suffix
                self.Flags[flag] = value
                pcall(callback, value)
            end

            local inputBtn = Instance.new("TextButton")
            inputBtn.BackgroundTransparency = 1
            inputBtn.Size = UDim2.new(1, 0, 0, 20)
            inputBtn.Position = UDim2.new(0, 0, 0, 26)
            inputBtn.Text = ""
            inputBtn.ZIndex = 7
            inputBtn.Parent = frame

            inputBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                    UpdateSlider(input)
                end
            end)

            inputBtn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)

            local sliderObj = {}
            function sliderObj:Set(val)
                value = math.clamp(val, min, max)
                local percent = (value - min) / (max - min)
                CreateTween(sliderFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.2):Play()
                CreateTween(sliderKnob, {Position = UDim2.new(percent, 0, 0.5, 0)}, 0.2):Play()
                valueLabel.Text = tostring(value) .. suffix
                self.Flags[flag] = value
                pcall(callback, value)
            end
            function sliderObj:Get()
                return value
            end
            return sliderObj
        end

        -- ═══════════════════════════════════
