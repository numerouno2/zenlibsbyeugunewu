            local function Upd()
                if toggled then
                    tw(track, {BackgroundColor3 = T.Accent1}, 0.25)
                    tw(tStroke, {Color = T.Accent1, Transparency = 0.3}, 0.25)
                    tw(knob, {Position = UDim2.new(1,-21,0.5,-9), BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(0,18,0,18)}, 0.25, Enum.EasingStyle.Back)
