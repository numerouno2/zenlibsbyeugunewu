        if not self.MobileSize then
            TabButton.MouseEnter:Connect(function()
                if self.CurrentTab ~= tab then
                    CreateTween(TabButton, {BackgroundTransparency = 0.4}, 0.15):Play()
                end
            end)
            TabButton.MouseLeave:Connect(function()
                if self.CurrentTab ~= tab then
                    CreateTween(TabButton, {BackgroundTransparency = 0.7}, 0.15):Play()
                end
            end)
        end

        table.insert(self.Tabs, tab)

        -- Auto-select first tab
        if #self.Tabs == 1 then
