    -- ═══════════════════════════════════════
    -- DESTROY METHOD
    -- ═══════════════════════════════════════
    function self:Destroy()
        AntiAFK.Active = false
        self.ScreenGui:Destroy()
    end

    -- ═══════════════════════════════════════
    -- GET FLAG VALUE
    -- ═══════════════════════════════════════
    function self:GetFlag(flag)
        return self.Flags[flag]
    end

    -- Startup notification
    spawn(function()
        wait(0.5)
        self:Notify({
            Title = "Zenith UI Loaded",
            Message = "Anti-AFK is active. Press " .. self.MinimizeKey.Name .. " to toggle UI.",
            Type = "Success",
            Duration = 3
        })
    end)

    return self
end

return ZenithLib
