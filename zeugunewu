local isMobile = UIS.TouchEnabled and not UIS.KeyboardEnabled

local function tw(obj, props, dur, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(dur or 0.3, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

local function addStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(255,255,255)
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0.85
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function addCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 10)
    c.Parent = parent
    return c
end

local function addPadding(parent, t, b, l, r)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, t or 0)
    p.PaddingBottom = UDim.new(0, b or 0)
    p.PaddingLeft = UDim.new(0, l or 0)
    p.PaddingRight = UDim.new(0, r or 0)
    p.Parent = parent
    return p
end

local function addLayout(parent, dir, pad, align, sort)
    local l = Instance.new("UIListLayout")
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.Padding = UDim.new(0, pad or 6)
    l.HorizontalAlignment = align or Enum.HorizontalAlignment.Center
    l.SortOrder = sort or Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

local function addGradient(parent, c1, c2, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c1, c2)
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

local function rippleEffect(parent, x, y)
    local r = Instance.new("Frame")
    r.BackgroundColor3 = Color3.new(1,1,1)
    r.BackgroundTransparency = 0.75
    r.BorderSizePixel = 0
    r.AnchorPoint = Vector2.new(0.5,0.5)
    r.ZIndex = parent.ZIndex + 5
    addCorner(r, 999)
    r.Position = UDim2.new(0, x - parent.AbsolutePosition.X, 0, y - parent.AbsolutePosition.Y)
    r.Size = UDim2.new(0,0,0,0)
    r.Parent = parent
    local m = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 3
    tw(r, {Size = UDim2.new(0,m,0,m), BackgroundTransparency = 1}, 0.6).Completed:Connect(function() r:Destroy() end)
end

