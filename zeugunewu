            selLbl.ZIndex = 11
            selLbl.Parent = f
            glow(selLbl, T.AccentGlow, 0.7)

            local arw = Instance.new("TextLabel")
            arw.BackgroundTransparency = 1
            arw.Size = UDim2.new(0,18,0,36)
            arw.Position = UDim2.new(1,-22,0,0)
            arw.Font = Enum.Font.Code
            arw.Text = "▾"
            arw.TextColor3 = T.TextDark
            arw.TextSize = 12
            arw.ZIndex = 11
            arw.Rotation = 0
            arw.Parent = f

            local oc = Instance.new("Frame")
            oc.BackgroundTransparency = 1
            oc.Size = UDim2.new(1,-16,0,0)
            oc.Position = UDim2.new(0,8,0,38)
            oc.ClipsDescendants = true
            oc.ZIndex = 11
            oc.Parent = f
            lay(oc, Enum.FillDirection.Vertical, 2)

            local optBtns = {}
            local function Build()
                for _,b in pairs(optBtns) do b:Destroy() end; optBtns={}
                for _,opt in ipairs(opts) do
                    local ob = Instance.new("TextButton")
                    ob.BackgroundColor3 = T.Surface
                    ob.BackgroundTransparency = 0.4
                    ob.Size = UDim2.new(1,0,0,24)
                    ob.Font = Enum.Font.Code
                    ob.Text = "  " .. opt:lower()
                    ob.TextColor3 = T.TextDim
                    ob.TextSize = 11
                    ob.TextXAlignment = Enum.TextXAlignment.Left
                    ob.BorderSizePixel = 0
                    ob.AutoButtonColor = false
                    ob.ZIndex = 12
                    ob.Parent = oc
                    c(ob, 2)

                    local isSel = multi and sel[opt] or (sel==opt)
                    if isSel then
                        ob.Text = "► " .. opt:lower()
                        ob.TextColor3 = T.Accent
                        glow(ob, T.AccentGlow, 0.7)
                        ob.BackgroundTransparency = 0.15
                    end

                    ob.MouseButton1Click:Connect(function()
                        if multi then
                            sel[opt] = not sel[opt]
                            if sel[opt] then
                                ob.Text = "► " .. opt:lower()
                                tw(ob,{TextColor3=T.Accent,BackgroundTransparency=0.15},0.15)
                                glow(ob, T.AccentGlow, 0.7)
                            else
                                ob.Text = "  " .. opt:lower()
                                tw(ob,{TextColor3=T.TextDim,BackgroundTransparency=0.4},0.15)
                                ob.TextStrokeTransparency = 1
                            end
                        else
                            sel = opt
                            for _,b in pairs(optBtns) do
                                b.Text = "  " .. b.Name
                                tw(b,{TextColor3=T.TextDim,BackgroundTransparency=0.4},0.15)
                                b.TextStrokeTransparency = 1
                            end
                            ob.Text = "► " .. opt:lower()
                            tw(ob,{TextColor3=T.Accent,BackgroundTransparency=0.15},0.15)
                            glow(ob, T.AccentGlow, 0.7)
                        end
                        selLbl.Text = "[" .. GetTxt() .. "]"
                        lib.Flags[flag]=sel; pcall(cb,sel)
                    end)

                    ob.Name = opt:lower()
                    ob.MouseEnter:Connect(function() tw(ob,{BackgroundTransparency=0.1},0.1) end)
                    ob.MouseLeave:Connect(function() local is=multi and sel[opt] or sel==opt; if not is then tw(ob,{BackgroundTransparency=0.4},0.1) end end)
                    table.insert(optBtns, ob)
                end
            end
            Build()

            local hb = Instance.new("TextButton")
            hb.BackgroundTransparency=1; hb.Size=UDim2.new(1,0,0,36); hb.Text=""; hb.ZIndex=16; hb.Parent=f

            hb.MouseButton1Click:Connect(function()
                opened = not opened
                if opened then
                    local th = #opts * 26 + 4
                    tw(f,{Size=UDim2.new(1,0,0,36+th+6)},0.25,Enum.EasingStyle.Quint)
                    tw(oc,{Size=UDim2.new(1,-16,0,th)},0.25,Enum.EasingStyle.Quint)
                    tw(arw,{Rotation=180},0.25)
                else
                    tw(f,{Size=UDim2.new(1,0,0,36)},0.25,Enum.EasingStyle.Quint)
                    tw(oc,{Size=UDim2.new(1,-16,0,0)},0.25,Enum.EasingStyle.Quint)
                    tw(arw,{Rotation=0},0.25)
                end
            end)

            return {Set=function(_,v) sel=v; selLbl.Text="["..GetTxt().."]"; lib.Flags[flag]=sel; pcall(cb,sel) end, Refresh=function(_,no) opts=no; Build() end, Get=function() return sel end}
        end

        -- ── TEXTBOX ──
        function tab:AddTextbox(cfg4)
            cfg4 = cfg4 or {}
            local name = cfg4.Name or "input"
            local flag = cfg4.Flag or name
            local def = cfg4.Default or ""
            local cb = cfg4.Callback or function() end
            lib.Flags[flag] = def

            local f = Card(36)

            local nl2 = Instance.new("TextLabel")
            nl2.BackgroundTransparency = 1
            nl2.Size = UDim2.new(0.35,0,1,0)
            nl2.Position = UDim2.new(0,10,0,0)
            nl2.Font = Enum.Font.Code
            nl2.Text = "$ " .. name:lower():gsub(" ","_")
            nl2.TextColor3 = T.Text
            nl2.TextSize = 11
            nl2.TextXAlignment = Enum.TextXAlignment.Left
            nl2.ZIndex = 11
            nl2.Parent = f
            glow(nl2, T.AccentGlow, 0.85)

            local ibg = Instance.new("Frame")
            ibg.BackgroundColor3 = T.Bg
            ibg.BorderSizePixel = 0
            ibg.Size = UDim2.new(0.58,0,0,24)
            ibg.Position = UDim2.new(0.4,0,0.5,-12)
            ibg.ZIndex = 11
            ibg.Parent = f
            c(ibg, 2)
            local iStr = s(ibg, T.Border, 1, 0.5)

            local tb = Instance.new("TextBox")
            tb.BackgroundTransparency = 1
            tb.Size = UDim2.new(1,-10,1,0)
            tb.Position = UDim2.new(0,5,0,0)
            tb.Font = Enum.Font.Code
            tb.Text = def
            tb.PlaceholderText = cfg4.Placeholder or "type_here..."
            tb.PlaceholderColor3 = T.TextDark
            tb.TextColor3 = T.Accent
            tb.TextSize = 11
            tb.TextXAlignment = Enum.TextXAlignment.Left
            tb.ClearTextOnFocus = false
            tb.ZIndex = 12
            tb.Parent = ibg
            glow(tb, T.AccentGlow, 0.7)

            tb.Focused:Connect(function() tw(iStr,{Color=T.Accent,Transparency=0.2},0.2) end)
            tb.FocusLost:Connect(function(ep) tw(iStr,{Color=T.Border,Transparency=0.5},0.2); lib.Flags[flag]=tb.Text; pcall(cb,tb.Text,ep) end)

            return {Set=function(_,v) tb.Text=v; lib.Flags[flag]=v end, Get=function() return tb.Text end}
        end

        -- ── KEYBIND ──
        function tab:AddKeybind(cfg4)
            cfg4 = cfg4 or {}
            local name = cfg4.Name or "keybind"
            local flag = cfg4.Flag or name
            local key = cfg4.Default or Enum.KeyCode.Unknown
            local cb = cfg4.Callback or function() end
            local listening = false
            lib.Flags[flag] = key

            local f = Card(36)

            local nl2 = Instance.new("TextLabel")
            nl2.BackgroundTransparency = 1
            nl2.Size = UDim2.new(0.6,0,1,0)
            nl2.Position = UDim2.new(0,10,0,0)
            nl2.Font = Enum.Font.Code
            nl2.Text = name:lower():gsub(" ","_")
            nl2.TextColor3 = T.Text
            nl2.TextSize = 11
            nl2.TextXAlignment = Enum.TextXAlignment.Left
            nl2.ZIndex = 11
            nl2.Parent = f
            glow(nl2, T.AccentGlow, 0.85)

            local kb = Instance.new("TextButton")
            kb.BackgroundColor3 = T.Bg
            kb.Size = UDim2.new(0,65,0,22)
            kb.Position = UDim2.new(1,-75,0.5,-11)
            kb.Font = Enum.Font.Code
            kb.Text = "[" .. (key.Name or "?") .. "]"
            kb.TextColor3 = T.Accent
            kb.TextSize = 10
            kb.BorderSizePixel = 0
            kb.AutoButtonColor = false
            kb.ZIndex = 12
            kb.Parent = f
            c(kb, 2)
            local kStr = s(kb, T.Border, 1, 0.5)
            glow(kb, T.AccentGlow, 0.65)

            kb.MouseButton1Click:Connect(function()
                listening = true; kb.Text = "[···]"
                tw(kStr,{Color=T.Accent,Transparency=0.2},0.2)
            end)

            UIS.InputBegan:Connect(function(i,g)
                if listening and i.UserInputType==Enum.UserInputType.Keyboard then
                    key=i.KeyCode; kb.Text="["..key.Name.."]"; lib.Flags[flag]=key; listening=false
                    tw(kStr,{Color=T.Border,Transparency=0.5},0.2)
                elseif not g and not listening and i.KeyCode==key then pcall(cb) end
            end)
        end

        -- ── COLOR PICKER ──
        function tab:AddColorPicker(cfg4)
            cfg4 = cfg4 or {}
            local name = cfg4.Name or "color"
            local flag = cfg4.Flag or name
            local col = cfg4.Default or Color3.new(1,0,0)
            local cb = cfg4.Callback or function() end
            local op = false
            lib.Flags[flag] = col
            local h2,s2,v2 = col:ToHSV()

            local f = Card(36)
            f.ClipsDescendants = true

            local nl2 = Instance.new("TextLabel")
            nl2.BackgroundTransparency = 1
            nl2.Size = UDim2.new(1,-55,0,36)
            nl2.Position = UDim2.new(0,10,0,0)
            nl2.Font = Enum.Font.Code
            nl2.Text = name:lower():gsub(" ","_")
            nl2.TextColor3 = T.Text
            nl2.TextSize = 11
            nl2.TextXAlignment = Enum.TextXAlignment.Left
            nl2.ZIndex = 11
            nl2.Parent = f
            glow(nl2, T.AccentGlow, 0.85)

            local cpv = Instance.new("Frame")
            cpv.BackgroundColor3 = col
            cpv.Size = UDim2.new(0,24,0,18)
            cpv.Position = UDim2.new(1,-34,0.5,-9)
            cpv.ZIndex = 12
            cpv.Parent = f
            c(cpv, 2)
            s(cpv, Color3.new(1,1,1), 1, 0.7)

            local pa = Instance.new("Frame")
            pa.BackgroundTransparency = 1
            pa.Size = UDim2.new(1,-20,0,0)
            pa.Position = UDim2.new(0,10,0,40)
            pa.ClipsDescendants = true
            pa.ZIndex = 12
            pa.Parent = f

            local function MkBar(yP, gc)
                local bar = Instance.new("Frame")
                bar.BackgroundColor3 = Color3.new(1,1,1)
                bar.Size = UDim2.new(1,0,0,12)
                bar.Position = UDim2.new(0,0,0,yP)
                bar.ZIndex = 13
                bar.Parent = pa
                c(bar, 2)
                local g = Instance.new("UIGradient"); g.Color=gc; g.Parent=bar
                local b = Instance.new("TextButton"); b.BackgroundTransparency=1; b.Size=UDim2.new(1,0,1,0); b.Text=""; b.ZIndex=15; b.Parent=bar
                return bar,g,b
            end

            local hB,hG,hBtn = MkBar(0, ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)),
                ColorSequenceKeypoint.new(0.17,Color3.fromHSV(0.17,1,1)),
                ColorSequenceKeypoint.new(0.33,Color3.fromHSV(0.33,1,1)),
                ColorSequenceKeypoint.new(0.5,Color3.fromHSV(0.5,1,1)),
                ColorSequenceKeypoint.new(0.67,Color3.fromHSV(0.67,1,1)),
                ColorSequenceKeypoint.new(0.83,Color3.fromHSV(0.83,1,1)),
                ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1)),
            }))
            local sB,sG,sBtn = MkBar(16, ColorSequence.new(Color3.new(1,1,1),Color3.fromHSV(h2,1,1)))
            local vB,vG,vBtn = MkBar(32, ColorSequence.new(Color3.new(0,0,0),Color3.fromHSV(h2,s2,1)))

            local function UC()
                col=Color3.fromHSV(h2,s2,v2); cpv.BackgroundColor3=col
                sG.Color=ColorSequence.new(Color3.new(1,1,1),Color3.fromHSV(h2,1,1))
                vG.Color=ColorSequence.new(Color3.new(0,0,0),Color3.fromHSV(h2,s2,1))
                lib.Flags[flag]=col; pcall(cb,col)
            end

            local hd,sd,vd = false,false,false
            hBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then hd=true end end)
            hBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then hd=false end end)
            sBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sd=true end end)
            sBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sd=false end end)
            vBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then vd=true end end)
            vBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then vd=false end end)

            UIS.InputChanged:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                    if hd then h2=math.clamp((i.Position.X-hB.AbsolutePosition.X)/hB.AbsoluteSize.X,0,1); UC() end
                    if sd then s2=math.clamp((i.Position.X-sB.AbsolutePosition.X)/sB.AbsoluteSize.X,0,1); UC() end
                    if vd then v2=math.clamp((i.Position.X-vB.AbsolutePosition.X)/vB.AbsoluteSize.X,0,1); UC() end
                end
            end)

            local cpb = Instance.new("TextButton"); cpb.BackgroundTransparency=1; cpb.Size=UDim2.new(1,0,0,36); cpb.Text=""; cpb.ZIndex=16; cpb.Parent=f
            cpb.MouseButton1Click:Connect(function()
                op = not op
                if op then
                    tw(f,{Size=UDim2.new(1,0,0,95)},0.25,Enum.EasingStyle.Quint)
                    tw(pa,{Size=UDim2.new(1,-20,0,48)},0.25,Enum.EasingStyle.Quint)
                else
                    tw(f,{Size=UDim2.new(1,0,0,36)},0.25,Enum.EasingStyle.Quint)
                    tw(pa,{Size=UDim2.new(1,-20,0,0)},0.25,Enum.EasingStyle.Quint)
                end
            end)
        end

        return tab
    end

    function lib:GetFlag(f2) return lib.Flags[f2] end
    function lib:Destroy() _afk=false; SG:Destroy() end

    -- Startup notify after boot
    task.spawn(function()
        task.wait(2.5)
        lib:Notify({Title="SYSTEM READY", Message="Terminal loaded. Anti-AFK: ACTIVE. Toggle: "..lib.Key.Name, Type="Success", Duration=3})
    end)

    return lib
end

return ZenithLib
