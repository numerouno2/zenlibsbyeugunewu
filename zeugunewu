        tab.Page = Page

        local function SelectTab()
            for _, t in ipairs(lib.Tabs) do
                t.Page.Visible = false
                if isMobile then
                    tw(t.Button, {BackgroundTransparency = 0.4, TextColor3 = T.TextMuted}, 0.2)
                else
                    tw(t.Button, {BackgroundTransparency = 0.6}, 0.2)
                    if t._icon then tw(t._icon, {TextColor3 = T.TextMuted}, 0.2) end
                    if t._label then tw(t._label, {TextColor3 = T.TextMuted}, 0.2) end
                    if t._indicator then tw(t._indicator, {BackgroundTransparency = 1}, 0.2) end
                end
            end
            Page.Visible = true
            if isMobile then
                tw(TabBtn, {BackgroundTransparency = 0.1, TextColor3 = T.Text}, 0.25)
                TabBtn.BackgroundColor3 = T.Accent1
            else
                tw(TabBtn, {BackgroundTransparency = 0.2, BackgroundColor3 = T.Accent1}, 0.25)
