                    tw(knob, {Position = UDim2.new(0,3,0.5,-9), BackgroundColor3 = T.TextSub, Size = UDim2.new(0,18,0,18)}, 0.25, Enum.EasingStyle.Back)
                end
            end

            local btn = Instance.new("TextButton")
            btn.BackgroundTransparency = 1
            btn.Size = UDim2.new(1,0,1,0)
            btn.Text = ""
            btn.ZIndex = 15
            btn.Parent = f

            btn.MouseButton1Click:Connect(function()
                toggled = not toggled; lib.Flags[flag] = toggled; Upd(); pcall(cb, toggled)
            end)
            btn.MouseEnter:Connect(function() tw(f, {BackgroundTransparency = 0.05}, 0.15) end)
            btn.MouseLeave:Connect(function() tw(f, {BackgroundTransparency = 0.15}, 0.15) end)

            if toggled then Upd() end
            return {Set = function(_,v) toggled=v; lib.Flags[flag]=v; Upd(); pcall(cb,v) end, Get = function() return toggled end}
        end

        -- SLIDER
        function tab:AddSlider(c)
            c = c or {}
            local name = c.Name or "Slider"
            local flag = c.Flag or name
            local min,max = c.Min or 0, c.Max or 100
            local val = math.clamp(c.Default or min, min, max)
            local inc = c.Increment or 1
            local suf = c.Suffix or ""
            local cb = c.Callback or function() end
            lib.Flags[flag] = val

            local f = Card(56)

            local l = Instance.new("TextLabel")
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(0.55,0,0,22)
            l.Position = UDim2.new(0,14,0,4)
            l.Font = Enum.Font.GothamSemibold
            l.Text = name
            l.TextColor3 = T.Text
            l.TextSize = 13
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.ZIndex = 11
            l.Parent = f

            -- Value pill
            local vPill = Instance.new("Frame")
            vPill.BackgroundColor3 = T.Accent1
            vPill.BackgroundTransparency = 0.8
            vPill.Size = UDim2.new(0, 55, 0, 20)
            vPill.Position = UDim2.new(1, -65, 0, 5)
            vPill.ZIndex = 11
            vPill.Parent = f
            addCorner(vPill, 6)

            local vl = Instance.new("TextLabel")
            vl.BackgroundTransparency = 1
            vl.Size = UDim2.new(1,0,1,0)
            vl.Font = Enum.Font.GothamBold
            vl.Text = tostring(val)..suf
            vl.TextColor3 = T.Accent1
            vl.TextSize = 11
            vl.ZIndex = 12
            vl.Parent = vPill

            -- Track
            local bg = Instance.new("Frame")
            bg.BackgroundColor3 = T.Slider
            bg.BorderSizePixel = 0
            bg.Size = UDim2.new(1,-28,0,6)
            bg.Position = UDim2.new(0,14,0,38)
            bg.ZIndex = 11
            bg.Parent = f
            addCorner(bg, 3)

            local pct = (val-min)/(max-min)
            local fill = Instance.new("Frame")
            fill.BackgroundColor3 = T.Accent1
            fill.BorderSizePixel = 0
            fill.Size = UDim2.new(pct,0,1,0)
            fill.ZIndex = 12
            fill.Parent = bg
            addCorner(fill, 3)
            addGradient(fill, T.Accent1, T.Accent2, 0)

            -- Glow knob
            local sk = Instance.new("Frame")
            sk.BackgroundColor3 = Color3.new(1,1,1)
            sk.BorderSizePixel = 0
            sk.Size = UDim2.new(0,16,0,16)
            sk.AnchorPoint = Vector2.new(0.5,0.5)
            sk.Position = UDim2.new(pct,0,0.5,0)
            sk.ZIndex = 14
            sk.Parent = bg
            addCorner(sk, 8)
            addStroke(sk, T.Accent1, 2, 0.2)

            local sliding = false

            local function UpdSlider(input)
                local rel = math.clamp((input.Position.X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
                val = math.clamp(math.floor((min+(max-min)*rel)/inc+0.5)*inc, min, max)
                local p = (val-min)/(max-min)
                tw(fill, {Size = UDim2.new(p,0,1,0)}, 0.05)
                tw(sk, {Position = UDim2.new(p,0,0.5,0)}, 0.05)
                vl.Text = tostring(val)..suf
                lib.Flags[flag] = val
                pcall(cb, val)
            end

            local ib = Instance.new("TextButton")
            ib.BackgroundTransparency = 1
            ib.Size = UDim2.new(1,0,0,24)
            ib.Position = UDim2.new(0,0,0,28)
            ib.Text = ""
            ib.ZIndex = 16
            ib.Parent = f

            ib.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    sliding = true; UpdSlider(i)
                    tw(sk, {Size = UDim2.new(0,20,0,20)}, 0.15, Enum.EasingStyle.Back)
                end
            end)
            ib.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    sliding = false
                    tw(sk, {Size = UDim2.new(0,16,0,16)}, 0.15)
                end
            end)
            UIS.InputChanged:Connect(function(i) if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then UpdSlider(i) end end)

            return {
                Set = function(_,v2) val=math.clamp(v2,min,max); local p=(val-min)/(max-min); tw(fill,{Size=UDim2.new(p,0,1,0)},0.2); tw(sk,{Position=UDim2.new(p,0,0.5,0)},0.2); vl.Text=tostring(val)..suf; lib.Flags[flag]=val; pcall(cb,val) end,
                Get = function() return val end
            }
        end

        -- DROPDOWN
        function tab:AddDropdown(c)
            c = c or {}
            local name = c.Name or "Dropdown"
            local flag = c.Flag or name
            local opts = c.Options or {}
            local multi = c.Multi or false
            local sel = multi and {} or (c.Default or opts[1] or "")
            local cb = c.Callback or function() end
            local opened = false

            if multi and type(c.Default)=="table" then for _,v in ipairs(c.Default) do sel[v]=true end end
            lib.Flags[flag] = sel

            local f = Card(42)
            f.ClipsDescendants = true

            local l = Instance.new("TextLabel")
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(0.4,-10,0,42)
            l.Position = UDim2.new(0,14,0,0)
            l.Font = Enum.Font.GothamSemibold
            l.Text = name
            l.TextColor3 = T.Text
            l.TextSize = 13
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.ZIndex = 11
            l.Parent = f

            local function GetTxt()
                if multi then
                    local it = {}; for k,v in pairs(sel) do if v then table.insert(it,k) end end
                    return #it>0 and table.concat(it,", ") or "None"
                end
                return tostring(sel)
            end

            local sl = Instance.new("TextLabel")
            sl.BackgroundTransparency = 1
            sl.Size = UDim2.new(0.5,-10,0,42)
            sl.Position = UDim2.new(0.4,0,0,0)
            sl.Font = Enum.Font.Gotham
            sl.Text = GetTxt()
            sl.TextColor3 = T.Accent1
            sl.TextSize = 11
            sl.TextXAlignment = Enum.TextXAlignment.Right
            sl.TextTruncate = Enum.TextTruncate.AtEnd
            sl.ZIndex = 11
            sl.Parent = f

            local arw = Instance.new("TextLabel")
            arw.BackgroundTransparency = 1
            arw.Size = UDim2.new(0,20,0,42)
            arw.Position = UDim2.new(1,-25,0,0)
            arw.Font = Enum.Font.GothamBold
            arw.Text = "▾"
            arw.TextColor3 = T.TextMuted
            arw.TextSize = 12
            arw.ZIndex = 11
            arw.Rotation = 0
            arw.Parent = f

            local oc = Instance.new("Frame")
            oc.BackgroundTransparency = 1
            oc.Size = UDim2.new(1,-20,0,0)
            oc.Position = UDim2.new(0,10,0,44)
            oc.ClipsDescendants = true
            oc.ZIndex = 11
            oc.Parent = f
            addLayout(oc, Enum.FillDirection.Vertical, 3)

            local optBtns = {}
            local function Build()
                for _,b in pairs(optBtns) do b:Destroy() end; optBtns = {}
                for _,opt in ipairs(opts) do
                    local ob = Instance.new("TextButton")
                    ob.BackgroundColor3 = T.Elevated
                    ob.BackgroundTransparency = 0.4
                    ob.Size = UDim2.new(1,0,0,30)
                    ob.Font = Enum.Font.Gotham
                    ob.Text = "  "..opt
                    ob.TextColor3 = T.TextSub
                    ob.TextSize = 12
                    ob.TextXAlignment = Enum.TextXAlignment.Left
                    ob.BorderSizePixel = 0
                    ob.AutoButtonColor = false
                    ob.ZIndex = 12
                    ob.Parent = oc
                    addCorner(ob, 7)

                    local isSel = multi and sel[opt] or (sel==opt)
                    if isSel then ob.TextColor3 = T.Accent1; ob.BackgroundTransparency = 0.15 end

                    ob.MouseButton1Click:Connect(function()
                        if multi then
                            sel[opt] = not sel[opt]
                            tw(ob, {TextColor3 = sel[opt] and T.Accent1 or T.TextSub, BackgroundTransparency = sel[opt] and 0.15 or 0.4}, 0.15)
                        else
                            sel = opt
                            for _,b in pairs(optBtns) do tw(b, {TextColor3 = T.TextSub, BackgroundTransparency = 0.4}, 0.15) end
                            tw(ob, {TextColor3 = T.Accent1, BackgroundTransparency = 0.15}, 0.15)
                        end
                        sl.Text = GetTxt(); lib.Flags[flag] = sel; pcall(cb, sel)
                    end)
                    ob.MouseEnter:Connect(function() tw(ob, {BackgroundTransparency = 0.15}, 0.1) end)
                    ob.MouseLeave:Connect(function() local is=multi and sel[opt] or sel==opt; if not is then tw(ob, {BackgroundTransparency = 0.4}, 0.1) end end)
                    table.insert(optBtns, ob)
                end
            end
            Build()

            local hb = Instance.new("TextButton")
            hb.BackgroundTransparency = 1; hb.Size = UDim2.new(1,0,0,42); hb.Text = ""; hb.ZIndex = 16; hb.Parent = f

            hb.MouseButton1Click:Connect(function()
                opened = not opened
                if opened then
                    local th = #opts * 33 + 4
                    tw(f, {Size = UDim2.new(1,0,0,42+th+8)}, 0.3, Enum.EasingStyle.Quint)
                    tw(oc, {Size = UDim2.new(1,-20,0,th)}, 0.3, Enum.EasingStyle.Quint)
                    tw(arw, {Rotation = 180}, 0.3)
                else
                    tw(f, {Size = UDim2.new(1,0,0,42)}, 0.3, Enum.EasingStyle.Quint)
                    tw(oc, {Size = UDim2.new(1,-20,0,0)}, 0.3, Enum.EasingStyle.Quint)
                    tw(arw, {Rotation = 0}, 0.3)
                end
            end)

            return {Set = function(_,v) sel=v; sl.Text=GetTxt(); lib.Flags[flag]=sel; pcall(cb,sel) end, Refresh = function(_,no) opts=no; Build() end, Get = function() return sel end}
        end

        -- TEXTBOX
        function tab:AddTextbox(c)
            c = c or {}
            local name = c.Name or "Input"
            local flag = c.Flag or name
            local def = c.Default or ""
            local cb = c.Callback or function() end
            lib.Flags[flag] = def

            local f = Card(42)

            local l = Instance.new("TextLabel")
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(0.38,0,1,0)
            l.Position = UDim2.new(0,14,0,0)
            l.Font = Enum.Font.GothamSemibold
            l.Text = name
            l.TextColor3 = T.Text
            l.TextSize = 13
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.ZIndex = 11
            l.Parent = f

            local ibg = Instance.new("Frame")
            ibg.BackgroundColor3 = T.Input
            ibg.BorderSizePixel = 0
            ibg.Size = UDim2.new(0.55,0,0,28)
            ibg.Position = UDim2.new(0.42,0,0.5,-14)
            ibg.ZIndex = 11
            ibg.Parent = f
            addCorner(ibg, 8)
            local iStr = addStroke(ibg, T.Border, 1, 0.5)

            local tb = Instance.new("TextBox")
            tb.BackgroundTransparency = 1
            tb.Size = UDim2.new(1,-14,1,0)
            tb.Position = UDim2.new(0,7,0,0)
            tb.Font = Enum.Font.Gotham
            tb.Text = def
            tb.PlaceholderText = c.Placeholder or "Type..."
            tb.PlaceholderColor3 = T.TextMuted
            tb.TextColor3 = T.Text
            tb.TextSize = 12
            tb.TextXAlignment = Enum.TextXAlignment.Left
            tb.ClearTextOnFocus = false
            tb.ZIndex = 12
            tb.Parent = ibg

            tb.Focused:Connect(function() tw(iStr, {Color = T.Accent1, Transparency = 0.2}, 0.2) end)
            tb.FocusLost:Connect(function(ep) tw(iStr, {Color = T.Border, Transparency = 0.5}, 0.2); lib.Flags[flag]=tb.Text; pcall(cb, tb.Text, ep) end)

            return {Set = function(_,v) tb.Text = v; lib.Flags[flag]=v end, Get = function() return tb.Text end}
        end

        -- KEYBIND
        function tab:AddKeybind(c)
            c = c or {}
            local name = c.Name or "Keybind"
            local flag = c.Flag or name
            local key = c.Default or Enum.KeyCode.Unknown
            local cb = c.Callback or function() end
            local listening = false
            lib.Flags[flag] = key

            local f = Card(42)

            local l = Instance.new("TextLabel")
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(0.6,0,1,0)
            l.Position = UDim2.new(0,14,0,0)
            l.Font = Enum.Font.GothamSemibold
            l.Text = name
            l.TextColor3 = T.Text
            l.TextSize = 13
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.ZIndex = 11
            l.Parent = f

            local kb = Instance.new("TextButton")
            kb.BackgroundColor3 = T.Input
            kb.Size = UDim2.new(0,70,0,26)
            kb.Position = UDim2.new(1,-80,0.5,-13)
            kb.Font = Enum.Font.GothamBold
            kb.Text = key.Name or "None"
            kb.TextColor3 = T.Accent1
            kb.TextSize = 11
            kb.BorderSizePixel = 0
            kb.AutoButtonColor = false
            kb.ZIndex = 12
            kb.Parent = f
            addCorner(kb, 7)
            local kStr = addStroke(kb, T.Border, 1, 0.5)

            kb.MouseButton1Click:Connect(function()
                listening = true; kb.Text = "···"
                tw(kStr, {Color = T.Accent1, Transparency = 0.2}, 0.2)
                tw(kb, {BackgroundColor3 = T.Accent1, TextColor3 = Color3.new(1,1,1)}, 0.2)
            end)

            UIS.InputBegan:Connect(function(i,g)
                if listening and i.UserInputType==Enum.UserInputType.Keyboard then
                    key = i.KeyCode; kb.Text = key.Name; lib.Flags[flag]=key; listening = false
                    tw(kStr, {Color = T.Border, Transparency = 0.5}, 0.2)
                    tw(kb, {BackgroundColor3 = T.Input, TextColor3 = T.Accent1}, 0.2)
                elseif not g and not listening and i.KeyCode == key then pcall(cb) end
            end)
        end

        -- COLOR PICKER
        function tab:AddColorPicker(c)
            c = c or {}
            local name = c.Name or "Color"
            local flag = c.Flag or name
            local col = c.Default or Color3.new(1,1,1)
            local cb = c.Callback or function() end
            local op = false
            lib.Flags[flag] = col
            local h,s,v = col:ToHSV()

            local f = Card(42)
            f.ClipsDescendants = true

            local l = Instance.new("TextLabel")
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(1,-55,0,42)
            l.Position = UDim2.new(0,14,0,0)
            l.Font = Enum.Font.GothamSemibold
            l.Text = name
            l.TextColor3 = T.Text
            l.TextSize = 13
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.ZIndex = 11
            l.Parent = f

            local cp = Instance.new("Frame")
            cp.BackgroundColor3 = col
            cp.Size = UDim2.new(0,26,0,26)
            cp.Position = UDim2.new(1,-38,0.5,-13)
            cp.ZIndex = 12
            cp.Parent = f
            addCorner(cp, 7)
            addStroke(cp, Color3.new(1,1,1), 1, 0.7)

            local pa = Instance.new("Frame")
            pa.BackgroundTransparency = 1
            pa.Size = UDim2.new(1,-24,0,0)
            pa.Position = UDim2.new(0,12,0,46)
            pa.ClipsDescendants = true
            pa.ZIndex = 12
            pa.Parent = f

            local function MakeBar(yP, gc)
                local bar = Instance.new("Frame")
                bar.BackgroundColor3 = Color3.new(1,1,1)
                bar.Size = UDim2.new(1,0,0,14)
                bar.Position = UDim2.new(0,0,0,yP)
                bar.ZIndex = 13
                bar.Parent = pa
                addCorner(bar, 4)
                local g = Instance.new("UIGradient"); g.Color = gc; g.Parent = bar
                local b = Instance.new("TextButton"); b.BackgroundTransparency=1; b.Size=UDim2.new(1,0,1,0); b.Text=""; b.ZIndex=15; b.Parent=bar
                return bar, g, b
            end

            local hB,hG,hBtn = MakeBar(0, ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)),
                ColorSequenceKeypoint.new(0.17,Color3.fromHSV(0.17,1,1)),
                ColorSequenceKeypoint.new(0.33,Color3.fromHSV(0.33,1,1)),
                ColorSequenceKeypoint.new(0.5,Color3.fromHSV(0.5,1,1)),
                ColorSequenceKeypoint.new(0.67,Color3.fromHSV(0.67,1,1)),
                ColorSequenceKeypoint.new(0.83,Color3.fromHSV(0.83,1,1)),
                ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1)),
            }))
            local sB,sG,sBtn = MakeBar(18, ColorSequence.new(Color3.new(1,1,1),Color3.fromHSV(h,1,1)))
            local vB,vG,vBtn = MakeBar(36, ColorSequence.new(Color3.new(0,0,0),Color3.fromHSV(h,s,1)))

            local function UC()
                col = Color3.fromHSV(h,s,v); cp.BackgroundColor3 = col
                sG.Color = ColorSequence.new(Color3.new(1,1,1),Color3.fromHSV(h,1,1))
                vG.Color = ColorSequence.new(Color3.new(0,0,0),Color3.fromHSV(h,s,1))
                lib.Flags[flag]=col; pcall(cb,col)
            end

            local hd,sd,vd = false,false,false
            hBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then hd=true end end)
            hBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then hd=false end end)
            sBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sd=true end end)
            sBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sd=false end end)
            vBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then vd=true end end)
            vBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then vd=false end end)

            UIS.InputChanged:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                    if hd then h=math.clamp((i.Position.X-hB.AbsolutePosition.X)/hB.AbsoluteSize.X,0,1); UC() end
                    if sd then s=math.clamp((i.Position.X-sB.AbsolutePosition.X)/sB.AbsoluteSize.X,0,1); UC() end
                    if vd then v=math.clamp((i.Position.X-vB.AbsolutePosition.X)/vB.AbsoluteSize.X,0,1); UC() end
                end
            end)

            local cpb = Instance.new("TextButton"); cpb.BackgroundTransparency=1; cpb.Size=UDim2.new(1,0,0,42); cpb.Text=""; cpb.ZIndex=16; cpb.Parent=f
            cpb.MouseButton1Click:Connect(function()
                op = not op
                if op then
                    tw(f, {Size = UDim2.new(1,0,0,105)}, 0.3, Enum.EasingStyle.Quint)
                    tw(pa, {Size = UDim2.new(1,-24,0,55)}, 0.3, Enum.EasingStyle.Quint)
                else
                    tw(f, {Size = UDim2.new(1,0,0,42)}, 0.3, Enum.EasingStyle.Quint)
                    tw(pa, {Size = UDim2.new(1,-24,0,0)}, 0.3, Enum.EasingStyle.Quint)
                end
            end)
        end

        return tab
    end

    function lib:GetFlag(f) return lib.Flags[f] end
    function lib:Destroy() _afk=false; SG:Destroy() end

    task.spawn(function()
        task.wait(0.6)
        lib:Notify({Title = "Zenith v3.0 Loaded", Message = "Anti-AFK active • Press "..lib.ToggleKey.Name.." to toggle", Type = "Success", Duration = 3})
    end)

    return lib
end

return ZenithLib
