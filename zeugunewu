                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        keyBtn.Text = currentKey.Name
                        self.Flags[flag] = currentKey
                        listening = false
                        CreateTween(keyBtn, {BackgroundColor3 = self.Theme.Input}, 0.15):Play()
                        CreateTween(keyBtn, {TextColor3 = self.Theme.Accent}, 0.15):Play()
                    end
                elseif not gpe and input.KeyCode == currentKey then
                    pcall(callback)
                end
            end)
        end

        -- ═══════════════════════════════════
        -- COLOR PICKER
        -- ═══════════════════════════════════
        function tab:AddColorPicker(config)
            config = config or {}
            local name = config.Name or "Color"
            local flag = config.Flag or name
            local default = config.Default or Color3.fromRGB(255, 255, 255)
            local callback = config.Callback or function() end

            local currentColor = default
            local opened2 = false
            self.Flags[flag] = currentColor

            local frame = CreateElementFrame(38)
            frame.ClipsDescendants = true

            local label = Instance.new("TextLabel")
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(1, -55, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.Font = Enum.Font.GothamSemibold
            label.Text = name
            label.TextColor3 = self.Theme.Text
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 4
            label.Parent = frame

            -- Color preview
            local colorPreview = Instance.new("Frame")
            colorPreview.BackgroundColor3 = currentColor
            colorPreview.Size = UDim2.new(0, 30, 0, 20)
            colorPreview.Position = UDim2.new(1, -40, 0.5, -10)
            colorPreview.ZIndex = 5
            colorPreview.Parent = frame

            local cpCorner = Instance.new("UICorner")
            cpCorner.CornerRadius = UDim.new(0, 6)
            cpCorner.Parent = colorPreview

            -- Color picker area
            local pickerArea = Instance.new("Frame")
            pickerArea.BackgroundTransparency = 1
            pickerArea.Size = UDim2.new(1, -20, 0, 0)
            pickerArea.Position = UDim2.new(0, 10, 0, 42)
            pickerArea.ClipsDescendants = true
            pickerArea.ZIndex = 5
            pickerArea.Parent = frame

            -- Hue bar
            local hueBar = Instance.new("Frame")
            hueBar.BackgroundColor3 = Color3.new(1, 1, 1)
            hueBar.Size = UDim2.new(1, 0, 0, 18)
            hueBar.Position = UDim2.new(0, 0, 0, 0)
            hueBar.ZIndex = 6
            hueBar.Parent = pickerArea

            local hueCorner = Instance.new("UICorner")
            hueCorner.CornerRadius = UDim.new(0, 4)
            hueCorner.Parent = hueBar

            local hueGrad = Instance.new("UIGradient")
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
                ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
                ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
                ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            })
            hueGrad.Parent = hueBar

            -- RGB Sliders simple
            local h, s, v = currentColor:ToHSV()

            local hueSlider = Instance.new("TextButton")
            hueSlider.BackgroundTransparency = 1
            hueSlider.Size = UDim2.new(1, 0, 1, 0)
            hueSlider.Text = ""
            hueSlider.ZIndex = 7
            hueSlider.Parent = hueBar

            -- Saturation bar
            local satBar = Instance.new("Frame")
            satBar.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            satBar.Size = UDim2.new(1, 0, 0, 18)
            satBar.Position = UDim2.new(0, 0, 0, 22)
            satBar.ZIndex = 6
            satBar.Parent = pickerArea

            local satCorner = Instance.new("UICorner")
            satCorner.CornerRadius = UDim.new(0, 4)
            satCorner.Parent = satBar

            local satGrad = Instance.new("UIGradient")
            satGrad.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromHSV(h, 1, 1))
            satGrad.Parent = satBar

            local satSlider = Instance.new("TextButton")
            satSlider.BackgroundTransparency = 1
            satSlider.Size = UDim2.new(1, 0, 1, 0)
            satSlider.Text = ""
            satSlider.ZIndex = 7
            satSlider.Parent = satBar

            -- Brightness bar
            local valBar = Instance.new("Frame")
            valBar.BackgroundColor3 = Color3.new(1, 1, 1)
            valBar.Size = UDim2.new(1, 0, 0, 18)
            valBar.Position = UDim2.new(0, 0, 0, 44)
            valBar.ZIndex = 6
            valBar.Parent = pickerArea

            local valCorner = Instance.new("UICorner")
            valCorner.CornerRadius = UDim.new(0, 4)
            valCorner.Parent = valBar

            local valGrad = Instance.new("UIGradient")
            valGrad.Color = ColorSequence.new(Color3.new(0, 0, 0), Color3.fromHSV(h, s, 1))
            valGrad.Parent = valBar

            local valSlider = Instance.new("TextButton")
            valSlider.BackgroundTransparency = 1
            valSlider.Size = UDim2.new(1, 0, 1, 0)
            valSlider.Text = ""
            valSlider.ZIndex = 7
            valSlider.Parent = valBar

            local function UpdateColor()
                currentColor = Color3.fromHSV(h, s, v)
                colorPreview.BackgroundColor3 = currentColor
                satGrad.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromHSV(h, 1, 1))
                valGrad.Color = ColorSequence.new(Color3.new(0, 0, 0), Color3.fromHSV(h, s, 1))
                self.Flags[flag] = currentColor
                pcall(callback, currentColor)
            end

            -- Hue interaction
            local hueDragging = false
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    hueDragging = true
                end
            end)
            hueSlider.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    hueDragging = false
                end
            end)

            -- Sat interaction
            local satDragging = false
            satSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    satDragging = true
                end
            end)
            satSlider.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    satDragging = false
                end
            end)

            -- Val interaction
            local valDragging = false
            valSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    valDragging = true
                end
            end)
            valSlider.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    valDragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    if hueDragging then
                        h = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    elseif satDragging then
                        s = math.clamp((input.Position.X - satBar.AbsolutePosition.X) / satBar.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    elseif valDragging then
                        v = math.clamp((input.Position.X - valBar.AbsolutePosition.X) / valBar.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    end
                end
            end)

            -- Toggle picker
            local cpBtn = Instance.new("TextButton")
            cpBtn.BackgroundTransparency = 1
            cpBtn.Size = UDim2.new(1, 0, 0, 38)
            cpBtn.Text = ""
            cpBtn.ZIndex = 6
            cpBtn.Parent = frame

            cpBtn.MouseButton1Click:Connect(function()
                opened2 = not opened2
                if opened2 then
                    CreateTween(frame, {Size = UDim2.new(1, 0, 0, 110)}, 0.25, Enum.EasingStyle.Quart):Play()
                    CreateTween(pickerArea, {Size = UDim2.new(1, -20, 0, 65)}, 0.25, Enum.EasingStyle.Quart):Play()
                else
                    CreateTween(frame, {Size = UDim2.new(1, 0, 0, 38)}, 0.25, Enum.EasingStyle.Quart):Play()
                    CreateTween(pickerArea, {Size = UDim2.new(1, -20, 0, 0)}, 0.25, Enum.EasingStyle.Quart):Play()
                end
            end)
        end

