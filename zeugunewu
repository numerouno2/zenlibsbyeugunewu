                if tab._label then tw(tab._label, {TextColor3 = Color3.new(1,1,1)}, 0.25) end
                if tab._indicator then tw(tab._indicator, {BackgroundTransparency = 0}, 0.25) end
            end
            lib.CurrentTab = tab
        end

        TabBtn.MouseButton1Click:Connect(SelectTab)

        if not isMobile then
            TabBtn.MouseEnter:Connect(function()
                if lib.CurrentTab ~= tab then
                    tw(TabBtn, {BackgroundTransparency = 0.35}, 0.15)
