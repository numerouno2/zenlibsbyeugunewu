local mob = UIS.TouchEnabled and not UIS.KeyboardEnabled

local function tw(o,p,d,s,dr)
    local t = TS:Create(o,TweenInfo.new(d or 0.25,s or Enum.EasingStyle.Quad,dr or Enum.EasingDirection.Out),p)
    t:Play() return t
end

local function c(p,r)
    local u = Instance.new("UICorner"); u.CornerRadius = UDim.new(0,r or 3); u.Parent = p; return u
end

local function s(p,col,th,tr)
    local u = Instance.new("UIStroke"); u.Color = col or Color3.new(1,1,1); u.Thickness = th or 1; u.Transparency = tr or 0.6
    u.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; u.Parent = p; return u
end

local function pad(p,t,b,l,r)
    local u = Instance.new("UIPadding"); u.PaddingTop=UDim.new(0,t or 0); u.PaddingBottom=UDim.new(0,b or 0)
    u.PaddingLeft=UDim.new(0,l or 0); u.PaddingRight=UDim.new(0,r or 0); u.Parent = p; return u
end

local function lay(p,dir,pd,al)
    local u = Instance.new("UIListLayout"); u.FillDirection=dir or Enum.FillDirection.Vertical
    u.Padding=UDim.new(0,pd or 5); u.HorizontalAlignment=al or Enum.HorizontalAlignment.Center
    u.SortOrder=Enum.SortOrder.LayoutOrder; u.Parent = p; return u
end

-- Neon glow on text
local function glow(lbl, col, intensity)
    lbl.TextStrokeColor3 = col
    lbl.TextStrokeTransparency = intensity or 0.72
end

-- Terminal prefix formatter
local function termFmt(prefix, text)
    return prefix .. " " .. text
end

